class_name BlockSdfBlender
## Spawn-time SDF smooth-union blender for element groups.
##
## Merges elements sharing a blend_group into a single organic mesh via
## Marching Cubes on a smooth-union SDF field. Runs once at spawn time —
## never per-frame. Output mesh is passed to BlockMeshMerger.
##
## Pipeline: block_builder → BlockSdfBlender → block_mesh_merger
##
## Usage (production — called by blocks_factory):
##   var mesh := BlockSdfBlender.blend(elements, blend_k, resolution)
##
## Usage (test scene — two explicit spheres):
##   var mesh := BlockSdfBlender.blend_spheres(pos_a, r_a, pos_b, r_b, k, res)
##
## See: /hd1/research/frogmog-sdf-blend.md


## Element descriptor for SDF evaluation. Built from block JSON by the factory.
class SdfElement:
	var shape: String       ## "sphere" | "box" | "cylinder"
	var center: Vector3     ## world/local position of element
	## sphere:   half_size.x = radius
	## box:      half_size = (hx, hy, hz) half-extents
	## cylinder: half_size.x = radius, half_size.y = half_height
	var half_size: Vector3
	var rotation_y: float = 0.0  ## local Y rotation in radians

	func _init(s: String, c: Vector3, hs: Vector3, ry: float = 0.0) -> void:
		shape = s; center = c; half_size = hs; rotation_y = ry


## ─────────────────────────────────────────────
##  Public API
## ─────────────────────────────────────────────

## Blend a list of SdfElements into a single ArrayMesh via Marching Cubes.
## blend_k  : smooth-union blend radius in meters (0 = hard union)
## resolution: voxel grid resolution (16=fast/rough, 32=standard, 64=fine)
## Returns null if no surface is found.
static func blend(elements: Array, blend_k: float, resolution: int = 32) -> ArrayMesh:
	if elements.is_empty():
		return null

	var padding := maxf(blend_k * 1.5, 0.3)
	var aabb := _compute_aabb(elements, padding)
	var grid := _sample_grid(elements, blend_k, aabb, resolution)
	return _marching_cubes(grid, aabb, resolution)


## Convenience: blend two spheres directly (used by the test scene).
static func blend_spheres(
		pos_a: Vector3, radius_a: float,
		pos_b: Vector3, radius_b: float,
		blend_k: float, resolution: int = 32) -> ArrayMesh:
	return blend([
		SdfElement.new("sphere", pos_a, Vector3(radius_a, 0.0, 0.0)),
		SdfElement.new("sphere", pos_b, Vector3(radius_b, 0.0, 0.0)),
	], blend_k, resolution)


## ─────────────────────────────────────────────
##  SDF Primitives  (Inigo Quilez signed distance functions)
## ─────────────────────────────────────────────

static func _sdf_sphere(p: Vector3, center: Vector3, radius: float) -> float:
	return (p - center).length() - radius


static func _sdf_box(p: Vector3, center: Vector3, half: Vector3) -> float:
	var q: Vector3 = (p - center).abs() - half
	return (Vector3(maxf(q.x, 0.0), maxf(q.y, 0.0), maxf(q.z, 0.0))).length() \
		+ minf(maxf(q.x, maxf(q.y, q.z)), 0.0)


static func _sdf_cylinder(p: Vector3, center: Vector3, radius: float, half_h: float) -> float:
	var lp := p - center
	var dx: float = Vector2(lp.x, lp.z).length() - radius
	var dy: float = absf(lp.y) - half_h
	return minf(maxf(dx, dy), 0.0) + Vector2(maxf(dx, 0.0), maxf(dy, 0.0)).length()


static func _element_sdf(p: Vector3, elem: SdfElement) -> float:
	var lp := p
	if not is_zero_approx(elem.rotation_y):
		var c := cos(-elem.rotation_y)
		var s := sin(-elem.rotation_y)
		lp = Vector3(p.x * c - p.z * s, p.y, p.x * s + p.z * c)
	match elem.shape:
		"sphere":   return _sdf_sphere(lp, elem.center, elem.half_size.x)
		"box":      return _sdf_box(lp, elem.center, elem.half_size)
		"cylinder": return _sdf_cylinder(lp, elem.center, elem.half_size.x, elem.half_size.y)
		_:          return _sdf_sphere(lp, elem.center, elem.half_size.length())


## Smooth union (IQ smin) across all elements.
static func _scene_sdf(p: Vector3, elements: Array, blend_k: float) -> float:
	var d := 1.0e9
	for elem: SdfElement in elements:
		var ed: float = _element_sdf(p, elem)
		if blend_k <= 0.0:
			d = minf(d, ed)
		else:
			var h: float = clampf(0.5 + 0.5 * (ed - d) / blend_k, 0.0, 1.0)
			d = lerpf(ed, d, h) - blend_k * h * (1.0 - h)
	return d


## ─────────────────────────────────────────────
##  Grid Sampling
## ─────────────────────────────────────────────

static func _compute_aabb(elements: Array, padding: float) -> AABB:
	var mn := Vector3(1.0e9, 1.0e9, 1.0e9)
	var mx := -mn
	for elem: SdfElement in elements:
		var r := maxf(elem.half_size.x, maxf(elem.half_size.y, elem.half_size.z))
		mn = mn.min(elem.center - Vector3(r, r, r))
		mx = mx.max(elem.center + Vector3(r, r, r))
	var pad := Vector3(padding, padding, padding)
	return AABB(mn - pad, (mx + pad) - (mn - pad))


## Sample SDF at (res+1)³ grid points. Returns flat PackedFloat32Array.
## Index: x + (res+1)*y + (res+1)²*z
static func _sample_grid(elements: Array, blend_k: float, aabb: AABB, res: int) -> PackedFloat32Array:
	var n := res + 1
	var total := n * n * n
	var grid: PackedFloat32Array
	grid.resize(total)
	var cell: Vector3 = aabb.size / float(res)
	var idx := 0
	for zi in range(n):
		for yi in range(n):
			for xi in range(n):
				var p: Vector3 = aabb.position + Vector3(xi, yi, zi) * cell
				grid[idx] = _scene_sdf(p, elements, blend_k)
				idx += 1
	return grid


## ─────────────────────────────────────────────
##  Marching Cubes
##  (Lorensen & Cline 1987 / Paul Bourke tables, public domain)
## ─────────────────────────────────────────────

## Cube vertex offsets in (x,y,z) voxel units. v0=(0,0,0)..v7=(0,1,1).
const _V: Array[Vector3] = [
	Vector3(0,0,0), Vector3(1,0,0), Vector3(1,0,1), Vector3(0,0,1),
	Vector3(0,1,0), Vector3(1,1,0), Vector3(1,1,1), Vector3(0,1,1),
]
## Each edge is a pair of vertex indices [a, b].
const _EP: Array = [
	[0,1],[1,2],[2,3],[3,0],  # e0-e3: bottom ring
	[4,5],[5,6],[6,7],[7,4],  # e4-e7: top ring
	[0,4],[1,5],[2,6],[3,7],  # e8-e11: vertical
]


static func _marching_cubes(grid: PackedFloat32Array, aabb: AABB, res: int) -> ArrayMesh:
	var n := res + 1
	var cell: Vector3 = aabb.size / float(res)
	var verts: PackedVector3Array
	var norms: PackedVector3Array

	for zi in range(res):
		for yi in range(res):
			for xi in range(res):
				# Sample 8 corner values and build cube index
				var vals: PackedFloat32Array
				vals.resize(8)
				var cube_idx := 0
				for v in range(8):
					var off: Vector3 = _V[v]
					var gx := xi + int(off.x)
					var gy := yi + int(off.y)
					var gz := zi + int(off.z)
					var d: float = grid[gx + n * gy + n * n * gz]
					vals[v] = d
					if d < 0.0:
						cube_idx |= (1 << v)

				if cube_idx == 0 or cube_idx == 255:
					continue

				var edge_bits: int = _EDGE_TABLE[cube_idx]
				if edge_bits == 0:
					continue

				# Interpolate edge crossing positions
				var ev: Array
				ev.resize(12)
				var cube_origin: Vector3 = aabb.position + Vector3(xi, yi, zi) * cell
				for e in range(12):
					if (edge_bits >> e) & 1:
						var va: int = _EP[e][0]
						var vb: int = _EP[e][1]
						var da: float = vals[va]
						var db: float = vals[vb]
						var t: float = 0.5
						if not is_equal_approx(da, db):
							t = clampf(da / (da - db), 0.0, 1.0)
						ev[e] = (cube_origin + _V[va] * cell).lerp(cube_origin + _V[vb] * cell, t)

				# Emit triangles
				var ti: int = cube_idx * 16
				var j := 0
				while j < 15:
					var e0: int = _TRI_TABLE[ti + j]
					if e0 == -1:
						break
					var p0: Vector3 = ev[e0]
					var p1: Vector3 = ev[_TRI_TABLE[ti + j + 1]]
					var p2: Vector3 = ev[_TRI_TABLE[ti + j + 2]]
					var n_vec: Vector3 = (p2 - p0).cross(p1 - p0).normalized()
					verts.append(p0); norms.append(n_vec)
					verts.append(p2); norms.append(n_vec)
					verts.append(p1); norms.append(n_vec)
					j += 3

	if verts.is_empty():
		return null

	var st := SurfaceTool.new()
	st.begin(Mesh.PRIMITIVE_TRIANGLES)
	for i in range(verts.size()):
		st.set_normal(norms[i])
		st.add_vertex(verts[i])
	st.index()
	return st.commit()


